      "source": [
        "## Reverse a String\n",
        "def reverse_string(s):\n",
        "  reversed_str = ' '\n",
        "\n",
        "  for i in range(len(s) -1, -1, -1):\n",
        "    reversed_str += s[i]\n",
        "\n",
        "  return reversed_str\n",
        "\n",
        "print(reverse_string(\"hello\"))\n",
        "print(reverse_string(\"python\"))"
      ]
    }
  ]
